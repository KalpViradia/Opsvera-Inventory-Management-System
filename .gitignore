# ========================
# Root .gitignore - Opsvera Monorepo
# ========================

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Build Output ---
.next/
out/
dist/
build/

# --- Environment Files ---
.env
.env.local
.env.*.local
# Keep .env.example checked in

# --- Testing ---
coverage/
playwright-report/
test-results/
playwright/

# --- Generated Reports ---
lighthouse-report.*

# --- OS Files ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Package Manager ---
pnpm-lock.yaml
pnpm-workspace.yaml

# --- Misc ---
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel

# --- AI Agent Files ---
AGENTS.md
CLAUDE.md

# --- Project Docs & Images (local reference only) ---
/Docs/
/Images/
