generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANT FOUNDATION
// ============================================

model Company {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  industry            String?
  currency            String   @default("USD")
  timezone            String   @default("UTC")
  logoUrl             String?
  fiscalYearStart     Int      @default(1) // Month number (1 = January)
  onboardingCompleted Boolean  @default(false)
  stockValuationMethod String  @default("WEIGHTED_AVERAGE") // "FIFO" | "WEIGHTED_AVERAGE"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users           User[]
  roles           Role[]
  rolePermissions RolePermission[]
  notifications   Notification[]
  activities      Activity[]
  ledgerAccounts  LedgerAccount[]
  journalEntries  JournalEntry[]
  customFields    CustomField[]
  sequences       Sequence[]
  invitations     Invitation[]
  webhooks        Webhook[]
  apiKeys         ApiKey[]
  priceLists      PriceList[]
  boms             BOM[]
  productionOrders ProductionOrder[]

  @@map("companies")
}

// ============================================
// SEQUENCES
// ============================================

model Sequence {
  id        String   @id @default(uuid())
  companyId String
  type      String   // "PO", "SO", etc.
  value     Int      @default(1)

  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, type])
  @@map("sequences")
}

// ============================================
// AUTHENTICATION (Better Auth managed)
// ============================================

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String? // Role name: "owner", "admin", "manager", "staff", "viewer"
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id])
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]
  activities    Activity[]
  journalEntries JournalEntry[]
  twoFactorEnabled Boolean?
  twofactors    TwoFactor[]

  @@unique([email])
  @@index([companyId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  role      String   // admin, manager, staff, viewer
  token     String   @unique
  status    String   @default("PENDING") // PENDING, ACCEPTED, CANCELLED
  expiresAt DateTime

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
  @@map("invitations")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("twoFactor")
}

// ============================================
// RBAC — ROLES & PERMISSIONS
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String // "owner", "admin", "manager", "staff", "viewer"
  label       String // Display name: "Owner", "Admin", etc.
  description String?
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  level       Int      @default(0) // Hierarchy level for comparison (higher = more access)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

model RolePermission {
  id         String  @id @default(uuid())
  module     String // "dashboard", "products", "inventory", "purchases", "sales", etc.
  canRead    Boolean @default(false)
  canWrite   Boolean @default(false)
  canDelete  Boolean @default(false)
  canApprove Boolean @default(false)
  roleId     String
  role       Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@index([companyId])
  @@index([roleId])
  @@map("role_permissions")
}

// ============================================
// PRODUCT CATALOG (Architecture — Step 8)
// ============================================

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductCategory {
  id          String            @id @default(uuid())
  name        String
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")
  companyId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("product_categories")
}

model ProductUnit {
  id        String   @id @default(uuid())
  name      String // e.g. "Piece", "Box", "Kg"
  code      String // e.g. "pcs", "box", "kg"
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("product_units")
}

model Product {
  id          String          @id @default(uuid())
  sku         String
  name        String
  description String?
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  unitId      String
  unit        ProductUnit     @relation(fields: [unitId], references: [id])
  status      ProductStatus   @default(DRAFT)
  minStockLevel Int           @default(0) // Added for Low Stock Alerts
  barcode     String?
  imageUrl    String?
  reorderQuantity    Int?
  preferredSupplierId String?
  averageCost Decimal @default(0) @db.Decimal(10, 2)
  
  // Dimensions & Weight
  weight      Decimal?  @db.Decimal(10, 3)  // kg
  length      Decimal?  @db.Decimal(10, 2)  // cm
  width       Decimal?  @db.Decimal(10, 2)
  height      Decimal?  @db.Decimal(10, 2)
  
  // Bundles
  isBundle    Boolean   @default(false)
  
  // Tracking
  isBatchTracked Boolean @default(false)

  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants           ProductVariant[]
  stockLevels        StockLevel[]
  stockEntries       StockEntry[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]
  quotationItems     QuotationItem[]
  serialNumbers      SerialNumber[]
  batches            Batch[]
  bundleItems        BundleItem[] @relation("BundleParent")
  partOfBundles      BundleItem[] @relation("BundleComponent")
  priceListItems     PriceListItem[]
  shipmentItems      ShipmentItem[]
  boms               BOM[]
  bomItems           BOMItem[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([companyId, status])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String?
  name      String // e.g. "Red / Large"
  price     Decimal  @db.Decimal(10, 2)
  cost      Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceListItems PriceListItem[]
  shipmentItems  ShipmentItem[]

  @@map("product_variants")
}

// [NEW] Bundle Component Model
model BundleItem {
  id              String   @id @default(uuid())
  bundleId        String
  bundle          Product  @relation("BundleParent", fields: [bundleId], references: [id])
  componentId     String
  component       Product  @relation("BundleComponent", fields: [componentId], references: [id])
  quantity        Int      @default(1)
  
  @@unique([bundleId, componentId])
  @@map("bundle_items")
}

// ============================================
// WAREHOUSE & INVENTORY (Module 5)
// ============================================

model Warehouse {
  id            String   @id @default(uuid())
  companyId     String
  name          String
  address       String?
  contactPerson String?
  phone         String?
  email         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  locations Location[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("warehouses")
}

model Location {
  id               String       @id @default(uuid())
  warehouseId      String
  warehouse        Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  companyId        String
  name             String // e.g. "Zone A", "Rack 1", "Shelf 2"
  description      String?
  parentLocationId String?
  parent           Location?    @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  children         Location[]   @relation("LocationHierarchy")
  stockLevels      StockLevel[]
  stockEntriesFrom StockEntry[] @relation("FromLocation")
  stockEntriesTo   StockEntry[] @relation("ToLocation")
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([warehouseId, name, parentLocationId]) // Name must be unique within its parent location/warehouse
  @@index([companyId])
  @@index([warehouseId])
  @@map("locations")
}

// ============================================
// INVENTORY & STOCK (Module 6)
// ============================================

enum StockEntryType {
  RECEIPT
  DELIVERY
  TRANSFER
  ADJUSTMENT
  SCRAP
}

model StockLevel {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  quantity    Int      @default(0)
  lastUpdated DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([locationId])
  @@index([productId])
  @@map("stock_levels")
}

model StockEntry {
  id             String         @id @default(uuid())
  companyId      String
  productId      String
  product        Product        @relation(fields: [productId], references: [id])
  fromLocationId String?
  fromLocation   Location?      @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     Location?      @relation("ToLocation", fields: [toLocationId], references: [id])
  quantity       Int
  remainingQty   Int            @default(0)
  unitCost       Decimal?       @db.Decimal(10, 2)
  type           StockEntryType
  refType        String? // e.g. "PURCHASE_ORDER", "SALES_ORDER"
  refId          String?
  notes          String?
  createdBy      String
  createdAt      DateTime       @default(now())

  @@index([companyId])
  @@index([productId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("stock_entries")
}

model SerialNumber {
  id           String    @id @default(uuid())
  companyId    String
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  serialNumber String
  status       String    @default("IN_STOCK") // IN_STOCK, SOLD, RETURNED, SCRAPPED
  locationId   String?
  customerId   String?   // If sold, linked to customer
  warrantyEnd  DateTime?
  createdAt    DateTime  @default(now())

  @@unique([companyId, productId, serialNumber])
  @@index([companyId])
  @@map("serial_numbers")
}

model Batch {
  id            String    @id @default(uuid())
  companyId     String
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  batchNumber   String
  quantity      Int       @default(0)
  locationId    String?
  manufacturedAt DateTime?
  expiresAt     DateTime?
  supplierId    String?
  notes         String?
  createdAt     DateTime  @default(now())

  @@unique([companyId, productId, batchNumber])
  @@index([companyId])
  @@index([expiresAt])
  @@map("batches")
}

// ============================================
// PROCUREMENT & SUPPLIERS (Module 7 & 8)
// ============================================

model Supplier {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  email        String?
  phone        String?
  address      String?
  paymentTerms Int? // e.g., 30 for Net 30
  taxId        String?
  bankDetails  String?
  rating       Int? // 1 to 5 scale
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("suppliers")
}

// ============================================
// CUSTOMERS & SALES (Module 9)
// ============================================

model Customer {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  email        String?
  phone        String?
  address      String?
  creditLimit  Decimal? @db.Decimal(12, 2)
  paymentTerms Int? // e.g., 30 for Net 30
  taxId        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesOrders   SalesOrder[]
  salesInvoices SalesInvoice[]
  quotations    Quotation[]
  
  priceListId   String?
  priceList     PriceList? @relation(fields: [priceListId], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
  @@map("customers")
}

// ============================================
// PURCHASE ORDERS & INVOICES (Module 8)
// ============================================

enum POStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

model PurchaseOrder {
  id          String    @id @default(uuid())
  companyId   String
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  poNumber    String
  status      POStatus  @default(DRAFT)
  totalAmount Decimal   @db.Decimal(12, 2)
  taxAmount   Decimal   @db.Decimal(12, 2)
  currency    String    @default("USD")
  exchangeRate Decimal  @default(1) @db.Decimal(10, 6)
  notes       String?
  createdBy   String
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items    PurchaseOrderItem[]
  invoices PurchaseInvoice[]

  @@unique([companyId, poNumber])
  @@index([companyId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String        @id @default(uuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal       @db.Decimal(10, 2)
  taxRate     Decimal       @default(0) @db.Decimal(5, 2)
  receivedQty Int           @default(0)
  total       Decimal       @db.Decimal(12, 2)

  @@map("purchase_order_items")
}

model PurchaseInvoice {
  id            String        @id @default(uuid())
  companyId     String
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id])
  supplierId    String
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  invoiceNumber String
  amount        Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2)
  createdAt     DateTime      @default(now())

  @@unique([companyId, invoiceNumber])
  @@map("purchase_invoices")
}

// ============================================
// SALES ORDERS & INVOICES (Module 10)
// ============================================

enum SOStatus {
  DRAFT
  CONFIRMED
  PACKED
  SHIPPED
  INVOICED
  CLOSED
  CANCELLED
}

model SalesOrder {
  id          String   @id @default(uuid())
  companyId   String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  soNumber    String
  status      SOStatus @default(DRAFT)
  totalAmount Decimal  @db.Decimal(12, 2)
  taxAmount   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  currency    String   @default("USD")
  exchangeRate Decimal @default(1) @db.Decimal(10, 6)
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items    SalesOrderItem[]
  invoices SalesInvoice[]
  shipments Shipment[]

  @@unique([companyId, soNumber])
  @@index([companyId, status])
  @@map("sales_orders")
}

model SalesOrderItem {
  id        String     @id @default(uuid())
  soId      String
  so        SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  productId String
  product   Product    @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal    @db.Decimal(10, 2)
  discount  Decimal    @default(0) @db.Decimal(10, 2)
  taxRate   Decimal    @default(0) @db.Decimal(5, 2)
  total     Decimal    @db.Decimal(12, 2)

  @@map("sales_order_items")
}

// ============================================
// PICK / PACK / SHIP (Fulfillment)
// ============================================

enum ShipmentStatus {
  PENDING
  PICKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Shipment {
  id              String         @id @default(uuid())
  companyId       String
  salesOrderId    String
  salesOrder      SalesOrder     @relation(fields: [salesOrderId], references: [id])
  shipmentNumber  String
  status          ShipmentStatus @default(PENDING)
  trackingNumber  String?
  carrier         String?
  shippingNotes   String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items           ShipmentItem[]

  @@unique([companyId, shipmentNumber])
  @@index([companyId, status])
  @@map("shipments")
}

model ShipmentItem {
  id          String   @id @default(uuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int

  @@map("shipment_items")
}

model SalesInvoice {
  id            String        @id @default(uuid())
  companyId     String
  soId          String
  so            SalesOrder    @relation(fields: [soId], references: [id])
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  invoiceNumber String
  amount        Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  paidAmount    Decimal       @default(0) @db.Decimal(12, 2)
  createdAt     DateTime      @default(now())

  @@unique([companyId, invoiceNumber])
  @@map("sales_invoices")
}

// ============================================
// QUOTATIONS (Module 10.5)
// ============================================

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id           String           @id @default(uuid())
  companyId    String
  customerId   String
  customer     Customer         @relation(fields: [customerId], references: [id])
  qtNumber     String
  status       QuotationStatus  @default(DRAFT)
  totalAmount  Decimal          @db.Decimal(12, 2)
  taxAmount    Decimal          @db.Decimal(12, 2)
  discount     Decimal          @default(0) @db.Decimal(12, 2)
  currency     String           @default("USD")
  validUntil   DateTime
  notes        String?
  createdBy    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  items        QuotationItem[]

  @@unique([companyId, qtNumber])
  @@index([companyId, status])
  @@map("quotations")
}

model QuotationItem {
  id           String     @id @default(uuid())
  quotationId  String
  quotation    Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Decimal    @db.Decimal(10, 2)
  discount     Decimal    @default(0) @db.Decimal(10, 2)
  taxRate      Decimal    @default(0) @db.Decimal(5, 2)
  total        Decimal    @db.Decimal(12, 2)

  @@map("quotation_items")
}

// ============================================
// PAYMENTS (AP / AR)
// ============================================

model Payment {
  id              String   @id @default(uuid())
  companyId       String
  type            String   // "INCOMING" (from customer) or "OUTGOING" (to supplier)
  invoiceType     String   // "SALES" or "PURCHASE"
  invoiceId       String   // salesInvoice.id or purchaseInvoice.id
  amount          Decimal  @db.Decimal(12, 2)
  method          String   // "BANK_TRANSFER", "CASH", "CHECK", "CARD"
  reference       String?  // External reference number
  notes           String?
  paidAt          DateTime @default(now())
  recordedBy      String
  createdAt       DateTime @default(now())

  @@index([companyId])
  @@index([invoiceType, invoiceId])
  @@map("payments")
}

// ============================================
// NOTIFICATIONS & ACTIVITY FEED
// ============================================

model Notification {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  isRead    Boolean  @default(false)
  link      String?  // Optional link to related entity
  createdAt DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model Activity {
  id          String   @id @default(uuid())
  companyId   String
  userId      String
  action      String   // e.g., "CREATED", "UPDATED", "DELETED"
  entityType  String   // e.g., "Product", "SalesOrder", "User"
  entityId    String
  details     String?  // JSON string or short description
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("activities")
}

// ============================================
// ACCOUNTING & FINANCE
// ============================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model LedgerAccount {
  id          String      @id @default(uuid())
  companyId   String
  code        String
  name        String
  type        AccountType
  parentId    String?
  isGroup     Boolean     @default(false)
  isActive    Boolean     @default(true)
  balance     Decimal     @default(0) @db.Decimal(15, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company     Company     @relation(fields: [companyId], references: [id])
  parent      LedgerAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    LedgerAccount[]   @relation("AccountHierarchy")
  journalItems JournalItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id          String    @id @default(uuid())
  companyId   String
  entryNumber String
  date        DateTime
  narration   String
  refType     String?   // "PURCHASE_ORDER", "SALES_ORDER", "MANUAL", etc.
  refId       String?
  totalAmount Decimal   @db.Decimal(15, 2)
  isPosted    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id])
  user        User      @relation(fields: [createdBy], references: [id])
  items       JournalItem[]

  @@unique([companyId, entryNumber])
  @@index([companyId, date])
  @@map("journal_entries")
}

model JournalItem {
  id              String   @id @default(uuid())
  journalEntryId  String
  accountId       String
  debit           Decimal  @default(0) @db.Decimal(15, 2)
  credit          Decimal  @default(0) @db.Decimal(15, 2)
  partyType       String?  // 'CUSTOMER', 'SUPPLIER', etc
  partyId         String?
  narration       String?

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         LedgerAccount      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_items")
}

// ============================================
// DYNAMIC CUSTOM FIELDS (Module 11)
// ============================================

model CustomField {
  id              String   @id @default(uuid())
  companyId       String
  moduleName      String   // 'products', 'customers', 'suppliers'
  fieldName       String
  fieldType       String   // 'text', 'number', 'date', 'dropdown', etc.
  isRequired      Boolean  @default(false)
  defaultValue    String?
  placeholder     String?
  helpText        String?
  validationRules Json?    // { min: 0, max: 100 }
  options         Json?    // ["Small", "Medium", "Large"]
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  company         Company  @relation(fields: [companyId], references: [id])
  values          CustomFieldValue[]

  @@unique([companyId, moduleName, fieldName])
  @@index([companyId, moduleName])
  @@map("custom_fields")
}

model CustomFieldValue {
  id         String   @id @default(uuid())
  fieldId    String
  entityId   String   // product_id, customer_id, etc.
  value      String   // stored as text, parsed based on fieldType
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  field      CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([entityId])
  @@map("custom_field_values")
}

// ============================================
// PLATFORM INTELLIGENCE & INTEGRATIONS (Phase 4)
// ============================================

model Webhook {
  id           String   @id @default(uuid())
  companyId    String
  url          String
  events       String[] // ["order.created", "stock.low"]
  secret       String   // For HMAC signing
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("webhooks")
}

model WebhookLog {
  id           String   @id @default(uuid())
  webhookId    String
  event        String
  payload      Json
  statusCode   Int?
  response     String?
  attempt      Int      @default(1)
  deliveredAt  DateTime @default(now())

  @@index([webhookId])
  @@map("webhook_logs")
}

model ApiKey {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  key          String   @unique
  scopes       String[] // ["read", "write", "admin"]
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  company      Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("api_keys")
}

// ============================================
// DYNAMIC PRICING (Phase 5)
// ============================================

model PriceList {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  description  String?
  currency     String   @default("USD")
  isActive     Boolean  @default(true)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company  @relation(fields: [companyId], references: [id])
  items        PriceListItem[]
  customers    Customer[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("price_lists")
}

model PriceListItem {
  id           String   @id @default(uuid())
  priceListId  String
  priceList    PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id])
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  price        Decimal   @db.Decimal(10, 2)
  minQuantity  Int       @default(1)

  @@unique([priceListId, productId, variantId, minQuantity])
  @@map("price_list_items")
}

// ============================================
// MANUFACTURING (Phase 5.3)
// ============================================

enum ProductionStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model BOM {
  id           String     @id @default(uuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id]) // Finished good
  name         String
  version      String     @default("1.0")
  notes        String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  items        BOMItem[]
  productionOrders ProductionOrder[]

  @@unique([companyId, productId, version])
  @@map("boms")
}

model BOMItem {
  id          String   @id @default(uuid())
  bomId       String
  bom         BOM      @relation(fields: [bomId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id]) // Component/Raw material
  quantity    Decimal  @db.Decimal(10, 2)
  notes       String?

  @@unique([bomId, productId])
  @@map("bom_items")
}

model ProductionOrder {
  id                String           @id @default(uuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  bomId             String
  bom               BOM              @relation(fields: [bomId], references: [id])
  orderNumber       String
  status            ProductionStatus @default(PLANNED)
  quantityToProduce Int
  startDate         DateTime?
  endDate           DateTime?
  notes             String?
  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([companyId, orderNumber])
  @@index([companyId, status])
  @@map("production_orders")
}
